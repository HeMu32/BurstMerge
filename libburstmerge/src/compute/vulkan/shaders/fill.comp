#version 460
#extension GL_GOOGLE_include_directive : enable
#include "common.glsl"

// fill: set every element of dst to pc.f0.
//   binding 0: dst (flat float array of pc.w*pc.h*pc.channels elements)
layout(binding = 0) buffer Dst { float dst[]; };

layout(local_size_x = 256) in;
void main()
{
    uint i = gl_GlobalInvocationID.x;
    uint n = uint(pc.w) * uint(pc.h) * uint(max(1, pc.channels));
    if (i >= n) return;
    dst[i] = pc.f0;
}
