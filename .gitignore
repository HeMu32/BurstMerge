# Build artifacts
/build/
/build*/
/CMakeFiles/
/CMakeCache.txt
/CMakeLists.txt.example
/*.cmake
/*.make
/*.ninja
/compile_commands.json
.cache/

# Visual Studio files
*.sln
*.vcxproj*
*.vcproj*
*.user
*.filters

# MinGW/Windows specific
*.exe
*.dll
*.lib
*.obj
*.o
*.pch
*.pdb

